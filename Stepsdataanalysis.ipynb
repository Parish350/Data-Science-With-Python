   "source": [
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "data = pd.read_csv(\"steps.csv\")\n",
    "x = data ['Day']\n",
    "y = data ['Steps']\n",
    "plt.bar(x,y)\n",
    "plt.axhline(10000)\n",
    "plt.xlabel(\"Day\")\n",
    "plt.ylabel(\"Steps\")\n",
    "plt.title(\"Daily Step Count(90 Days)\")\n",
    "plt.show()\n"
   ]
  }
